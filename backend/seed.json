{
  "model": "review.review",
  "pk": 3,
  "fields": {
    "user": 6,
    "title": "休日はファミリーも多め",
    "body": "晴れた日曜はランナー、犬の散歩、子どもの自転車練習などで賑やか。スピードは控えめ、ベルや声かけ必須。逆に平日は驚くほど空いていて、川と自分だけの世界を楽しめます。",
    "rating": "3.5",
    "created_at": "2025-12-25T16:35:23.201Z",
    "updated_at": "2026-01-04T17:11:39.696Z",
    "is_deleted": false,
    "deleted_at": null
  }
},
{
  "model": "review.review",
  "pk": 4,
  "fields": {
    "user": 1,
    "title": "寄り道が本気で楽しい！",
    "body": "友人とゆったりペースでサイクリング。道沿いには季節ごとに違う花畑があり、春は桜並木、秋はコスモスの絨毯が続きます。途中で見つけたカフェでアイスラテをテイクアウトして、河川敷でピクニック気分。地元のパン屋さんのカレーパンも最高。こういう寄り道の誘惑が多すぎて、予定よりゴールが3時間も遅れました。",
    "rating": "4.5",
    "created_at": "2025-12-25T17:00:19.957Z",
    "updated_at": "2026-01-04T16:54:11.926Z",
    "is_deleted": false,
    "deleted_at": null
  }
},
