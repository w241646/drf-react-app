{
  "model": "review.review",
  "pk": 6,
  "fields": {
    "user": 6,
    "title": "風の洗礼は覚悟",
    "body": "片道は軽快だったのに、帰りは強烈な向かい風でペダルが重く、同じ道なのに倍以上の時間がかかりました。風が川面を波立たせるのを横目に、ひたすら前傾姿勢で耐える時間もサイクリングの思い出のひとつ。後日、風向きを調べてルートを決める大切さを学びました。",
    "rating": "3.0",
    "created_at": "2025-12-25T17:20:14.608Z",
    "updated_at": "2026-01-04T17:11:05.474Z",
    "is_deleted": false,
    "deleted_at": null
  }
},
